# Backend API URL for production/deployed environments
# For local development: http://localhost:3001
# For ngrok: https://xxxx-xxxx-xxxx-xxxx.ngrok.io
# NOTE: Must include protocol (http/https) and NO trailing slash
# REQUIRED: Set this in Vercel environment variables when deploying
VITE_BACKEND_URL=http://localhost:3001

# Socket.IO server URL (optional, defaults to VITE_BACKEND_URL if not set)
# Use this only if your Socket.IO server is on a different domain
# VITE_SOCKET_URL=http://localhost:3001

# Google Maps API key (optional, only if using Google's visual map tiles)
# Default uses OpenStreetMap (free, no key needed)
# VITE_GOOGLE_MAPS_KEY=

# Supported languages (comma-separated)
# VITE_SUPPORTED_LANGUAGES=en,si,ta

# Voice wake words (comma-separated, lowercase)
# VITE_WAKE_WORDS=assistant,guide,navigator

# Voice confidence threshold (0-1)
# VITE_CONFIDENCE_THRESHOLD=0.75

# Emergency contact phone number (for SOS feature)
# VITE_EMERGENCY_CONTACT=

