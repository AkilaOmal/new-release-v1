{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install && chmod -R +x node_modules/.bin || true",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_BACKEND_URL": {
      "description": "Backend API URL (required for voice features). Set to your ngrok URL: https://xxxx-xxxx-xxxx-xxxx.ngrok.io"
    }
  },
  "buildEnv": {
    "VITE_BACKEND_URL": "@vite_backend_url"
  }
}
