PORT=3001
NODE_ENV=development

# Comma-separated, full origins (scheme + host, no trailing slash).
# ⚠️ IMPORTANT for Vercel + ngrok deployment:
#   - Local dev: http://localhost:5173
#   - Vercel + ngrok: https://your-project.vercel.app,http://localhost:5173
#   - Multiple: https://app1.vercel.app,https://app2.vercel.app
# UPDATE THIS when deploying to production!
FRONTEND_ORIGIN=http://localhost:5173

# Gemini (Google Generative AI)
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-1.5-flash

# ElevenLabs
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# --- Routing providers ---
# Default stack is fully open-source: OpenRouteService for routing/geocoding
# and OpenStreetMap (Overpass) for nearby POIs — no Google account required.

# OpenRouteService (free tier at https://openrouteservice.org/)
# Used for: walking routing + Pelias geocoding.
ORS_API_KEY=your_openrouteservice_key
# ORS_BASE_URL=https://api.openrouteservice.org

# Optional: Google Maps. Leave blank to run on the open-source stack.
# When set, you can switch the primary provider with ROUTING_PROVIDER=google,
# or leave it as a fallback.
GOOGLE_MAPS_API_KEY=

# Which routing provider to prefer. Auto-detects when omitted.
#   ROUTING_PROVIDER=ors
#   ROUTING_PROVIDER=google
ROUTING_PROVIDER=ors

# Optional: override the Overpass endpoint used for nearby POIs.
# OVERPASS_URL=https://overpass-api.de/api/interpreter

# Optional: rate limit overrides
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
